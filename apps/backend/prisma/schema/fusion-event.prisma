// ============================================================
//  MODEL FusionEvent  →  bảng "fusion_events"
//  Log mỗi lần user hợp thể (phục vụ quest/achievement fusion_count).
// ============================================================
model FusionEvent {
  id            BigInt   @id @default(autoincrement())
  user_id       Int
  recipe_id     Int? // ON DELETE SET NULL
  result_id     Int
  is_first_time Boolean  @default(false)
  created_at    DateTime @default(now())

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  recipe Recipe? @relation(fields: [recipe_id], references: [id], onDelete: SetNull)
  result Word    @relation(fields: [result_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@index([result_id])
  @@map("fusion_events")
}
