model AdministrativeUnit {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100)
  code        String  @unique @db.VarChar(20)
  parent_code String? @db.VarChar(20)
  level       Int

  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()
  created_by String?  @db.VarChar(50)
  updated_by String?  @db.VarChar(50)

  parent   AdministrativeUnit?  @relation("AdminUnitHierarchy", fields: [parent_code], references: [code], onDelete: SetNull)
  children AdministrativeUnit[] @relation("AdminUnitHierarchy")

  @@index([parent_code])
  @@map("administrative_units")
}
