# Sao chép file này thành .env và điền giá trị thật
# .env KHÔNG commit lên git, .env.example có commit

NODE_ENV=development
PORT=8080

# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/leng-me?schema=public"

# JWT — sinh chuỗi random, ví dụ: openssl rand -hex 32
JWT_ACCESS_SECRET="thay-bang-chuoi-random-toi-thieu-16-ky-tu"
JWT_REFRESH_SECRET="thay-bang-chuoi-random-KHAC-access-secret"
JWT_ACCESS_EXPIRES="15m"
REFRESH_TOKEN_TTL_DAYS=7
